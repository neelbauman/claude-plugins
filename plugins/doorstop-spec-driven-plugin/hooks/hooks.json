{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-yaml-edit.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '【SDD リマインダー】Doorstop YAML は doorstop_ops.py 経由で操作する。最後に validate_and_report.py --strict を実行する。YAML を直接 grep/edit しない。'"
          }
        ]
      }
    ]
  }
}
